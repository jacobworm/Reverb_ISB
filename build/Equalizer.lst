  69:Equalizer.cpp **** 
  70:Equalizer.cpp **** float Equalizer::incParameter(short band, PARAMETER param, float delta)
  71:Equalizer.cpp **** {
  72:Equalizer.cpp ****     //m_filterOn = true; // For test only
  73:Equalizer.cpp ****     if(param == PM_GAIN){
  74:Equalizer.cpp **** 		setParameter(band, param, m_EQParams[band].gain + delta);
  75:Equalizer.cpp **** 		updateEQParameters(band);
  76:Equalizer.cpp **** 		return m_EQParams[band].gain;
  77:Equalizer.cpp **** 	}
  78:Equalizer.cpp **** 	// Frekvensparameter vokser med en ratio. Skal evt være delta multipliceret med en konstant (her 
  79:Equalizer.cpp **** 	if(param == PM_FREQ){
  80:Equalizer.cpp **** 		setParameter(band, param, m_EQParams[band].fc * pow(2, 1.0/12.0));
  81:Equalizer.cpp **** 		updateEQParameters(band); 
  82:Equalizer.cpp **** 		return m_EQParams[band].fc;
  83:Equalizer.cpp **** 	}	
  84:Equalizer.cpp **** }
  85:Equalizer.cpp **** 
  86:Equalizer.cpp **** float Equalizer::decParameter(short band, PARAMETER param, float delta)
  87:Equalizer.cpp **** {
  88:Equalizer.cpp **** 	    //m_filterOn = true; // For test only
  89:Equalizer.cpp ****     if(param == PM_GAIN){
  90:Equalizer.cpp **** 		setParameter(band, param, m_EQParams[band].gain - delta);
  91:Equalizer.cpp **** 		updateEQParameters(band);
  92:Equalizer.cpp **** 		return m_EQParams[band].gain;
  93:Equalizer.cpp **** 	}
  94:Equalizer.cpp **** 	// Frekvensparameter vokser med en ratio. Skal evt være delta multipliceret med en konstant (her 
  95:Equalizer.cpp **** 	if(param == PM_FREQ){
  96:Equalizer.cpp **** 		setParameter(band, param, m_EQParams[band].fc / pow(2, 1.0/12.0));
  97:Equalizer.cpp **** 		updateEQParameters(band); 
  98:Equalizer.cpp **** 		return m_EQParams[band].fc;
  99:Equalizer.cpp **** 	}
 100:Equalizer.cpp **** }
 101:Equalizer.cpp **** 
 102:Equalizer.cpp **** void Equalizer::setParameter(short band, PARAMETER param, float value)
 103:Equalizer.cpp **** {
 104:Equalizer.cpp ****     bool update = false;
 105:Equalizer.cpp **** 	// float value_dB = pow(10.0,(value/20.0)); // Converting to dB
 106:Equalizer.cpp **** 	if (band < NUM_EQ_BANDS)
 107:Equalizer.cpp **** 	{
 108:Equalizer.cpp **** 		switch (param)
 109:Equalizer.cpp **** 		{
 110:Equalizer.cpp **** 			case PM_GAIN:
 111:Equalizer.cpp **** 				if (m_EQParams[band].gain != value) {
 112:Equalizer.cpp **** 					m_EQParams[band].gain = value;
 113:Equalizer.cpp **** 					update = true;
