  82:IIRFilter.h   **** 			float A = pow(10.0,(Gain_dB/40.0)); // Converting from dB to gain factor
  83:IIRFilter.h   **** 			float omega =  2.0 * float_PI * (fc / fs);
  84:IIRFilter.h   **** 			float alpha = sinf (omega) / (2.0 * Q);
