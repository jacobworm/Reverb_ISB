  28:FFT.h         **** 
  29:FFT.h         ****     // Initialize for given size (must be power of two)
  30:FFT.h         ****     // returns true on success
  31:FFT.h         ****     bool init(uint32_t size) 
  32:FFT.h         ****     {
  33:FFT.h         ****         if (!isPowerOfTwo(size)) return false;
  34:FFT.h         ****         freeBuffers();
  35:FFT.h         **** 
  36:FFT.h         ****         N = size;
  37:FFT.h         ****         log2N = computeLog2(N);
  38:FFT.h         **** 
  39:FFT.h         ****         // allocate tables
  40:FFT.h         ****         // twiddles: pairs of (cos, sin) for k=0..N/2-1 stored as [2*k], [2*k+1]
  41:FFT.h         ****         twiddles = new float[(N/2) * 2];
  42:FFT.h         ****         // bit reversal table
  43:FFT.h         ****         bitrev = new uint32_t[N];
  44:FFT.h         **** 
  45:FFT.h         ****         if (!twiddles || !bitrev) {
  46:FFT.h         ****             freeBuffers();
  47:FFT.h         ****             return false;
  48:FFT.h         ****         }
  49:FFT.h         **** 
  50:FFT.h         ****         computeTwiddles();
  51:FFT.h         ****         computeBitReversal();
  52:FFT.h         ****         return true;
  53:FFT.h         ****     }
  54:FFT.h         **** 
  55:FFT.h         ****     // In-place complex FFT
  56:FFT.h         ****     // real[], imag[] must be arrays of length N (set imag==0 for pure real input)
  57:FFT.h         ****     // inverse=false => forward FFT (sign = -1); inverse=true => inverse FFT (sign = +1) and scales
  58:FFT.h         ****     void fft(float* real, float* imag, bool inverse = false) 
  59:FFT.h         ****     {
  60:FFT.h         ****         assert(real && imag && N > 0);
  61:FFT.h         **** 
  62:FFT.h         ****         // 1) bit reversal reorder
  63:FFT.h         ****         for (uint32_t i = 0; i < N; ++i) {
  64:FFT.h         ****             uint32_t j = bitrev[i];
  65:FFT.h         ****             if (j > i) {
  66:FFT.h         ****                 float tmp = real[i]; real[i] = real[j]; real[j] = tmp;
  67:FFT.h         ****                 tmp = imag[i]; imag[i] = imag[j]; imag[j] = tmp;
  68:FFT.h         ****             }
  69:FFT.h         ****         }
  70:FFT.h         **** 
  71:FFT.h         ****         // 2) iterative Cooley-Tukey
  72:FFT.h         ****         // sign: -1 for forward, +1 for inverse (we precomputed twiddles for sign=-1)
  73:FFT.h         ****         //const float sign = inverse ? 1.0f : -1.0f;
  74:FFT.h         **** 
  75:FFT.h         ****         uint32_t halfSize = 1;
  76:FFT.h         ****         for (uint32_t stage = 1; stage <= (uint32_t)log2N; ++stage) {
  77:FFT.h         ****             uint32_t step = halfSize << 1;               // current FFT length
  78:FFT.h         ****             // twiddle step: index increment for twiddle table
  79:FFT.h         ****             uint32_t twStep = N / step;                  // how many twiddle indices between succes
  80:FFT.h         ****             for (uint32_t i = 0; i < N; i += step) {
  81:FFT.h         ****                 uint32_t twIndex = 0;
  82:FFT.h         ****                 for (uint32_t j = 0; j < halfSize; ++j) {
  83:FFT.h         ****                     // get twiddle (cos, sin) for index twIndex
ARM GAS  /var/folders/5f/72p4brfx5932kssh4q_5ly0m0000gn/T//cc7WxlGd.s 			page 26


  84:FFT.h         ****                     float wr = twiddles[2 * twIndex + 0];
  85:FFT.h         ****                     float wi = twiddles[2 * twIndex + 1];
  86:FFT.h         ****                     // if inverse, conjugate the twiddle (flip sign of sin)
  87:FFT.h         ****                     if (inverse) wi = -wi;
  88:FFT.h         **** 
  89:FFT.h         ****                     // butterfly: a = x[i+j], b = x[i+j+halfSize] * w
  90:FFT.h         ****                     uint32_t idxA = i + j;
  91:FFT.h         ****                     uint32_t idxB = i + j + halfSize;
  92:FFT.h         ****                     float ar = real[idxA];
  93:FFT.h         ****                     float ai = imag[idxA];
  94:FFT.h         ****                     float br = real[idxB];
  95:FFT.h         ****                     float bi = imag[idxB];
  96:FFT.h         **** 
  97:FFT.h         ****                     // complex multiply b * w
  98:FFT.h         ****                     float tr = br * wr - bi * wi;
  99:FFT.h         ****                     float ti = br * wi + bi * wr;
 100:FFT.h         **** 
 101:FFT.h         ****                     // combine
 102:FFT.h         ****                     real[idxA] = ar + tr;
 103:FFT.h         ****                     imag[idxA] = ai + ti;
 104:FFT.h         ****                     real[idxB] = ar - tr;
 105:FFT.h         ****                     imag[idxB] = ai - ti;
 106:FFT.h         **** 
 107:FFT.h         ****                     twIndex += twStep;
 108:FFT.h         ****                 }
 109:FFT.h         ****             }
 110:FFT.h         ****             halfSize = step;
 111:FFT.h         ****         }
 112:FFT.h         **** 
 113:FFT.h         ****         // scale for inverse FFT
 114:FFT.h         ****         if (inverse) {
 115:FFT.h         ****             float invN = 1.0f / float(N);
 116:FFT.h         ****             for (uint32_t i = 0; i < N; ++i) {
 117:FFT.h         ****                 real[i] *= invN;
 118:FFT.h         ****                 imag[i] *= invN;
 119:FFT.h         ****             }
 120:FFT.h         ****         }
 121:FFT.h         ****     }
 122:FFT.h         **** 
 123:FFT.h         ****     // Simple real-FFT wrapper
 124:FFT.h         ****     // inputReal length N -> outputComplexReal/Imag arrays length N/2+1 (DC..Nyquist)
 125:FFT.h         ****     // This implementation performs an N-point complex FFT with imag=0 then returns k=0..N/2
 126:FFT.h         ****     // Not the most optimized real-FFT, but simple and robust.
 127:FFT.h         ****     void realFft(const float* inputReal, float* outReal, float* outImag) 
 128:FFT.h         ****     {
 129:FFT.h         ****         assert(inputReal && outReal && outImag && N > 0);
 130:FFT.h         ****         // temporary buffers (caller may reuse real/imag arrays to avoid allocation)
 131:FFT.h         ****         // Here we allocate on heap once per class; for real-time systems you can provide external 
 132:FFT.h         ****         float* r = new float[N];
 133:FFT.h         ****         float* i = new float[N];
 134:FFT.h         ****         for (uint32_t k = 0; k < N; ++k) { r[k] = inputReal[k]; i[k] = 0.0f; }
 135:FFT.h         **** 
 136:FFT.h         ****         fft(r, i, false);
 137:FFT.h         **** 
 138:FFT.h         ****         // copy k=0..N/2
 139:FFT.h         ****         uint32_t half = N/2;
 140:FFT.h         ****         for (uint32_t k = 0; k <= half; ++k) {
ARM GAS  /var/folders/5f/72p4brfx5932kssh4q_5ly0m0000gn/T//cc7WxlGd.s 			page 27


 141:FFT.h         ****             outReal[k] = r[k];
 142:FFT.h         ****             outImag[k] = i[k];
 143:FFT.h         ****         }
 144:FFT.h         **** 
 145:FFT.h         ****         delete [] r;
 146:FFT.h         ****         delete [] i;
 147:FFT.h         ****     }
