 178:FFT.h         ****     // compute bit reversal for indices 0..N-1
 179:FFT.h         ****     void computeBitReversal() 
 180:FFT.h         ****     {
 181:FFT.h         ****         for (uint32_t i = 0; i < (uint32_t)N; ++i) {
 182:FFT.h         ****             bitrev[i] = bitReverse(i, log2N);
 183:FFT.h         ****         }
 184:FFT.h         ****     }
