 161:FFT.h         **** private:
 162:FFT.h         ****     uint32_t N;
 163:FFT.h         ****     int log2N;
 164:FFT.h         ****     float* twiddles;   // length = N/2 * 2 (cos,sin)
 165:FFT.h         ****     uint32_t* bitrev;  // length = N
 166:FFT.h         **** 
 167:FFT.h         ****     // compute twiddles for k=0..N/2-1 as cos(-2pi*k/N), sin(-2pi*k/N)
 168:FFT.h         ****     void computeTwiddles() 
 169:FFT.h         ****     {
 170:FFT.h         ****         const float TWO_PI = 6.283185307179586476925286766559f;
 171:FFT.h         ****         for (uint32_t k = 0; k < N/2; ++k) {
 172:FFT.h         ****             float angle = -TWO_PI * float(k) / float(N); // negative for forward FFT convention
 173:FFT.h         ****             twiddles[2*k + 0] = cosf(angle);
 174:FFT.h         ****             twiddles[2*k + 1] = sinf(angle);
 175:FFT.h         ****         }
ARM GAS  /var/folders/5f/72p4brfx5932kssh4q_5ly0m0000gn/T//cc7WxlGd.s 			page 90


