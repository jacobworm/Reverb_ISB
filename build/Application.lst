  42:Application.cpp **** void AudioCallback(AudioHandle::InputBuffer in, AudioHandle::OutputBuffer out, size_t size)
  43:Application.cpp **** {
  44:Application.cpp **** 	start = System::GetTick();
  45:Application.cpp **** 
  46:Application.cpp **** 	for (size_t i = 0; i < size; i++)
  47:Application.cpp **** 	{
  48:Application.cpp **** 		float sample = equalizerLeft.Process(in[0][i]); 
  49:Application.cpp **** 		fftMonitor.insertSample(sample);
  50:Application.cpp **** 		out[0][i] = sample;
  51:Application.cpp **** 		out[1][i] = equalizerRight.Process(in[1][i]);
  52:Application.cpp **** 
  53:Application.cpp **** 		// Bypass filter
  54:Application.cpp **** 		//out[0][i] = in[0][i];
  55:Application.cpp **** 		//out[1][i] = in[1][i];
  56:Application.cpp **** 	}
  57:Application.cpp **** 
  58:Application.cpp **** 	end = System::GetTick();
  59:Application.cpp **** 	dur = (end - start) * 5; // ns
  60:Application.cpp **** 	//dur = (end - start) / 200; // us
  61:Application.cpp **** }
